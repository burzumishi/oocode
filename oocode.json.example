  "hooks": {
    "enabled": true,
    "builtins": [
      "diff_after_write",
      "ctags_after_write",
      "lint_after_write",
      "quick_syntax_after_write",
      "lsp_after_write",
      "verify_after_edit",
      "test_suite_delta",
      "interface_change_detector",
      "config_syntax_after_write",
      "git_push_guard",
      "backup_before_write",
      "log_tool_calls",
      "test_after_write",
      "doc_validate_template_filled",
      "deadlock_detection",
      "dead_code_detection",
      "performance_profiling"
    ]
  },
  "snapshots": {
    "enabled": true,
    "maxSnapshots": 40,
    "saveOnCompact": true
  },
  "rag": {
    "enabled": true,
    "topK": 12,
    "similarityThreshold": 0.38,
    "maxSnippetChars": 20000,
    "indexInterval": 300.0,
    "topKComplex": 25,
    "thresholdComplex": 0.3,
    "complexMinChars": 150
  },
  "vision": {
    "enabled": true,
    "showIndicator": true
  },
  "chatlog": {
    "enabled": true,
    "path": "~/.oocode/logs/chat.log",
    "maxSizeMb": 10
  }
}
