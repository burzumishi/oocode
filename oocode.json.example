          "think_level": "off",
          "reasoning": false
        }
      },
      "carstenuhlig/omnicoder-9b:latest": {
        "contextWindow": 262144,
        "maxTokens": 80000,
        "params": {
          "num_ctx": 262144,
          "num_predict": 80000,
          "top_k": 20,
          "top_p": 0.95,
          "repeat_penalty": 1.0,
          "temperature": 0.4
        },
        "input": [
          "text"
        ],
        "timeoutSeconds": 900,
        "thinking": {
          "think_level": "off",
          "reasoning": false
        }
      },
      "aratan/qwen3.5-agent-multimodal:9b": {
        "contextWindow": 262144,
        "maxTokens": 80000,
        "params": {
          "num_ctx": 262144,
          "num_predict": 80000,
          "temperature": 0.5,
          "top_k": 20,
          "top_p": 0.95
        },
        "input": [
          "text",
          "image"
        ],
        "timeoutSeconds": 900,
        "thinking": {
          "think_level": "off",
          "reasoning": false
        }
      }
    }
  },
  "fallback": {
    "enabled": true,
    "model": "nexuz/qwen3.5-agent:4b",
    "timeoutSeconds": 900
  },
  "mcp": {
    "servers": [],
    "requestTimeout": 30.0,
    "oocodeAssistant": {
      "enabled": true
    },
    "systemAssistant": {
      "enabled": true
    },
    "homeOfficeAssistant": {
      "enabled": true
    },
    "securityAssistant": {
