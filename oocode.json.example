  "context": {
    "minKeep": 12,
    "compactThreshold": 0.8,
    "maxSummaryChars": 20000,
    "maxToolResultTokens": 20000,
    "autoContinueMax": 12,
    "cache_dir": "~/.oocode/cache",
    "prompt_cache_enabled": true,
    "prompt_cache_ttl": 3600,
    "context_window_configurable": true,
    "context_window_default": 262144,
    "context_window_min": 8192,
    "context_window_max": 262144
  },
  "embeddings": {
    "model": "nomic-embed-text-v2-moe:latest",
    "maxInputChars": 9000,
    "similarityThreshold": 0.3,
    "snippetChars": 1000,
    "topK": 12,
    "memoryEmbedEnabled": true
  },
  "tools": {
    "readFileLinesDefault": 5000,
    "readFileLinesWarnLarge": 10000,
    "webFetchMaxChars": 100000,
    "webFetchTimeout": 20,
    "webSearchMaxResults": 10,
    "bashMaxOutputChars": 1000000,
    "codeSearchMaxResults": 800,
    "codeSearchContextLines": 2000,
    "codeSearchMaxFilesize": "2M",
    "toolCacheEnabled": true,
    "toolCacheMaxSize": 2400
  },
  "workspace": {
    "maxMemoryLines": 600,
    "maxDailyChars": 32000
  },
  "searxng": {
    "url": "http://192.168.1.33:8888",
    "enabled": true,
    "maxResults": 8,
    "categories": "general",
    "language": "auto",
    "safeSearch": 0,
    "timeout": 30
  },
  "logging": {
    "enabled": true,
    "file": "~/.oocode/logs/oocode.log",
    "level": "info",
    "maxSizeMb": 5,
    "maxFiles": 3
  },
  "plugins": {
    "enabled": [
      "changelog",
      "clipboard",
      "embeddings_search",
      "lsp",
      "searxng",
      "test_runner",
      "todo",
      "tree_sitter",
      "vault"
    ]
  },
  "skills": {
    "enabled": [
      "converters",
      "snippets"
    ]
  },
  "appearance": {
    "accentColor": "cyan"
  },
  "pluginOptions": {
    "searxng": {
      "enabled": true
    },
    "lsp": {
      "requestTimeout": 10.0,
      "serverCmds": {},
      "autoStart": [
        ".py",
        ".js",
        ".ts",
        ".go",
        ".rs",
        ".c",
        ".cpp",
        ".rb",
        ".sh",
        ".json",
        ".yaml",
        ".sql",
        ".css",
        ".html",
        ".xml",
        ".md",
        ".spec"
      ]
    },
    "linter": {
      "auto": true,
      "maxOutput": 10000,
      "timeout": 30
    },
    "git": {
      "autostage": false,
      "showDiff": true
    }
  },
  "models": {
    "systemOverhead": 30000,
    "configs": {
      "qwen3.5:9b": {
        "contextWindow": 262144,
        "maxTokens": 80000,
        "params": {
          "num_ctx": 262144,
          "temperature": 0.5,
          "top_k": 20,
          "top_p": 0.95,
          "num_predict": 80000
        },
        "timeoutSeconds": 900,
        "thinking": {
          "think_level": "off",
          "reasoning": false
        },
        "input": [
          "text",
          "image"
        ]
      },
      "nexuz/qwen3.5-agent:4b": {
        "contextWindow": 262144,
        "maxTokens": 80000,
        "params": {
          "num_ctx": 262144,
          "num_predict": 80000,
          "repeat_penalty": 1.15,
          "temperature": 0.4,
          "top_k": 20,
          "top_p": 0.9
        },
        "timeoutSeconds": 900,
        "input": [
          "text",
          "image"
        ]
      },
      "qwen3.5:4b": {
        "contextWindow": 262144,
        "maxTokens": 80000,
        "params": {
          "num_ctx": 262144,
          "temperature": 0.4,
          "top_k": 20,
          "top_p": 0.95,
          "num_predict": 80000
        },
        "timeoutSeconds": 900,
        "input": [
          "text",
          "image"
        ]
      },
      "deepseek-r1:8b": {
        "contextWindow": 32768,
        "maxTokens": 12288,
        "params": {
          "num_ctx": 32768,
          "temperature": 0.6,
          "top_k": 20,
          "top_p": 0.95,
          "num_predict": 12288
        },
        "timeoutSeconds": 900,
        "input": [
          "text"
        ]
      },
      "batiai/qwen3.5-9b:latest": {
        "contextWindow": 262144,
        "maxTokens": 80000,
        "params": {
          "num_ctx": 262144,
          "top_p": 0.95,
          "temperature": 0.5,
          "top_k": 20,
          "num_predict": 80000
        },
        "input": [
          "text"
        ],
        "timeoutSeconds": 900,
